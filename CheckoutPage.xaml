<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Yum_Now.CheckoutPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFEFD5"
             Title="Bill Confirmation">

    <ScrollView>
        <VerticalStackLayout Padding="20,20" Spacing="14">
            <Button Text="Back"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start"
                    BackgroundColor="#FFF7EA"
                    TextColor="#6B3E26"
                    BorderColor="#BA9B80"
                    BorderWidth="1"
                    CornerRadius="10"
                    Padding="12,6" />

            <Label Text="Bill Confirmation"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#2E2E2E"
                   HorizontalOptions="Center" />

            <Border Stroke="#CFAF94"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#FFF8ED"
                    Padding="12,10">
                <VerticalStackLayout Spacing="3">
                    <Label Text="Restaurant"
                           FontSize="13"
                           TextColor="#7A6050" />
                    <Label x:Name="RestaurantNameLabel"
                           Text="-"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#2E2E2E" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Menu"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#2E2E2E" />

            <CollectionView x:Name="MenuCollection"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#D2B39A"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="#FFF7EA"
                                Padding="12"
                                Margin="0,4,0,4">
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#2A2A2A" />
                                <Label Grid.Column="1"
                                       Text="{Binding QtyText}"
                                       FontSize="15"
                                       TextColor="#6A6A6A" />
                                <Label Grid.Column="2"
                                       Text="{Binding LineTotalText}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#5A3D2D" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label x:Name="EmptyMenuLabel"
                   IsVisible="False"
                   Text="No selected menu items."
                   FontSize="14"
                   TextColor="#8A5A3A" />

            <Label Text="Delivery Address"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#2E2E2E"
                   Margin="0,4,0,0" />

            <Editor x:Name="AddressEditor"
                    AutoSize="TextChanges"
                    MinimumHeightRequest="90"
                    Placeholder="Enter your delivery address"
                    BackgroundColor="#FFF7EA"
                    TextColor="#2A2A2A"
                    PlaceholderColor="#8F7867" />

            <Label Text="Amount Confirmation"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#2E2E2E"
                   Margin="0,4,0,0" />

            <Border Stroke="#CFAF94"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#FFF8ED"
                    Padding="12,10">
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Subtotal"
                               FontSize="16"
                               TextColor="#4A3B31" />
                        <Label x:Name="SubtotalLabel"
                               Grid.Column="1"
                               FontSize="16"
                               TextColor="#4A3B31" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Delivery Fee"
                               FontSize="16"
                               TextColor="#4A3B31" />
                        <Label x:Name="DeliveryFeeLabel"
                               Grid.Column="1"
                               FontSize="16"
                               TextColor="#4A3B31" />
                    </Grid>
                    <BoxView HeightRequest="1"
                            BackgroundColor="#D5B79E" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total to Pay"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#2E2E2E" />
                        <Label x:Name="TotalLabel"
                               Grid.Column="1"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#2E2E2E" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button Text="Confirm Amount"
                    Clicked="OnConfirmAmountClicked"
                    HeightRequest="48"
                    CornerRadius="12"
                    BackgroundColor="#E6872F"
                    TextColor="White"
                    FontAttributes="Bold" />

            <Label x:Name="ConfirmMessageLabel"
                   IsVisible="False"
                   FontSize="14"
                   TextColor="#6A4A39" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
