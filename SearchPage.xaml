<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Yum_Now.SearchPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFEFD5"
             Title="Search Results">

    <ScrollView>
        <VerticalStackLayout Padding="20,18" Spacing="14">
            <Button Text="Back"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start"
                    BackgroundColor="#FFF7EA"
                    TextColor="#6B3E26"
                    BorderColor="#BA9B80"
                    BorderWidth="1"
                    CornerRadius="10"
                    Padding="12,6" />

            <Label Text="Internet Restaurant Search"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#2E2E2E"
                   HorizontalOptions="Center" />

            <Entry x:Name="TagEntry"
                   Placeholder="Type a tag (Chinese Restaurant / Sushi Restaurant / Indian Restaurant)"
                   BackgroundColor="#FFF7EA"
                   TextColor="#111111"
                   PlaceholderColor="#7A7A7A"
                   ClearButtonVisibility="WhileEditing" />

            <Button x:Name="SearchButton"
                    Text="Search on Internet"
                    Clicked="OnSearchClicked"
                    BackgroundColor="#E68A31"
                    TextColor="White"
                    CornerRadius="14"
                    FontAttributes="Bold" />

            <Grid>
                <VerticalStackLayout x:Name="IdleView" Spacing="6">
                    <Label x:Name="IdleMessageLabel"
                           Text="Type a tag and tap Search on Internet."
                           FontSize="15"
                           TextColor="#3A3A3A" />
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="LoadingView" IsVisible="False" Spacing="8" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="#E68A31" />
                    <Label Text="Searching restaurants..."
                           FontSize="15"
                           TextColor="#5A4638"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="ResultsView" IsVisible="False" Spacing="10">
                    <Label x:Name="ResultsInfoLabel"
                           FontSize="15"
                           TextColor="#3A3A3A" />

                    <CollectionView x:Name="ResultsCollection"
                                    SelectionMode="Single"
                                    SelectionChanged="OnResultSelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#6A6A6A"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="#FFF7EA"
                                        Padding="12"
                                        Margin="0,4,0,4">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding RestaurantName}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#222222" />
                                        <Label Text="{Binding MenuSummary}"
                                               FontSize="14"
                                               TextColor="#3A3A3A"
                                               LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="EmptyView" IsVisible="False" Spacing="6">
                    <Label x:Name="EmptyMessageLabel"
                           Text="No restaurant found."
                           FontSize="15"
                           TextColor="#5A4638" />
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="ErrorView" IsVisible="False" Spacing="10">
                    <Label x:Name="ErrorMessageLabel"
                           Text="Search failed."
                           FontSize="15"
                           TextColor="#9A3E2F" />
                    <Button Text="Try Again"
                            Clicked="OnRetryClicked"
                            BackgroundColor="#D8731E"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="44" />
                </VerticalStackLayout>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
