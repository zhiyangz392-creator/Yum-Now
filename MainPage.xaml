<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Yum_Now.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFEFD5">

    <ScrollView BackgroundColor="#FFEFD5">
        <VerticalStackLayout Padding="20,22,20,26" Spacing="16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="Back"
                        Clicked="OnBackClicked"
                        HorizontalOptions="Start"
                        BackgroundColor="#FFF7EA"
                        TextColor="#6B3E26"
                        BorderColor="#BA9B80"
                        BorderWidth="1"
                        CornerRadius="10"
                        Padding="12,6" />

                <Button Grid.Column="2"
                        Text="Logout"
                        Clicked="OnLogoutClicked"
                        HorizontalOptions="End"
                        BackgroundColor="#FFF7EA"
                        TextColor="#6B3E26"
                        BorderColor="#BA9B80"
                        BorderWidth="1"
                        CornerRadius="10"
                        Padding="12,6" />
            </Grid>

            <Border Stroke="#D1B59C"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="#FFF8ED"
                    Padding="14,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Home"
                           HorizontalOptions="Center"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="#2E2E2E" />
                    <Label Text="Choose a food type, then search."
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           FontSize="14"
                           TextColor="#7A6050" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Cuisine Tags"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#6B4C3B"
                   Margin="2,0,0,0" />

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">
                <Button x:Name="FastFoodButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Text="Fast Food Restaurant"
                        CommandParameter="Fast Food Restaurant"
                        Clicked="OnTagButtonClicked"
                        HeightRequest="64"
                        CornerRadius="14"
                        BackgroundColor="#FFF7EA"
                        TextColor="#1F1F1F"
                        BorderColor="#BA9B80"
                        BorderWidth="1"
                        Padding="10,6" />

                <Button x:Name="ChineseButton"
                        Grid.Row="0"
                        Grid.Column="1"
                        Text="Chinese Restaurant"
                        CommandParameter="Chinese Restaurant"
                        Clicked="OnTagButtonClicked"
                        HeightRequest="64"
                        CornerRadius="14"
                        BackgroundColor="#FFF7EA"
                        TextColor="#1F1F1F"
                        BorderColor="#BA9B80"
                        BorderWidth="1"
                        Padding="10,6" />

                <Button x:Name="IndianButton"
                        Grid.Row="1"
                        Grid.Column="0"
                        Text="Indian Restaurant"
                        CommandParameter="Indian Restaurant"
                        Clicked="OnTagButtonClicked"
                        HeightRequest="64"
                        CornerRadius="14"
                        BackgroundColor="#FFF7EA"
                        TextColor="#1F1F1F"
                        BorderColor="#BA9B80"
                        BorderWidth="1"
                        Padding="10,6" />

                <Button x:Name="SushiButton"
                        Grid.Row="1"
                        Grid.Column="1"
                        Text="Sushi Restaurant"
                        CommandParameter="Sushi Restaurant"
                        Clicked="OnTagButtonClicked"
                        HeightRequest="64"
                        CornerRadius="14"
                        BackgroundColor="#FFF7EA"
                        TextColor="#1F1F1F"
                        BorderColor="#BA9B80"
                        BorderWidth="1"
                        Padding="10,6" />

                <Button x:Name="SeafoodButton"
                        Grid.Row="2"
                        Grid.Column="0"
                        Text="Seafood Restaurant"
                        CommandParameter="Seafood Restaurant"
                        Clicked="OnTagButtonClicked"
                        HeightRequest="64"
                        CornerRadius="14"
                        BackgroundColor="#FFF7EA"
                        TextColor="#1F1F1F"
                        BorderColor="#BA9B80"
                        BorderWidth="1"
                        Padding="10,6" />

                <Button x:Name="CoffeeButton"
                        Grid.Row="2"
                        Grid.Column="1"
                        Text="Coffee Shop"
                        CommandParameter="Coffee Shop"
                        Clicked="OnTagButtonClicked"
                        HeightRequest="64"
                        CornerRadius="14"
                        BackgroundColor="#FFF7EA"
                        TextColor="#1F1F1F"
                        BorderColor="#BA9B80"
                        BorderWidth="1"
                        Padding="10,6" />
            </Grid>

            <Button Text="Search Restaurant"
                    Clicked="OnSearchClicked"
                    HorizontalOptions="Fill"
                    HeightRequest="58"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="#E6872F"
                    BorderColor="#C86E1B"
                    BorderWidth="1"
                    CornerRadius="14"
                    Margin="0,6,0,0" />

            <Border Stroke="#CBA98B"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#FFF8ED"
                    Padding="12,10">
                <Label x:Name="ResultLabel"
                       Text="Please select a tag and search."
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       FontSize="16"
                       TextColor="#4A3B31" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
